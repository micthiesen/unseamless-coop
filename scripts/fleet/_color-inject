#!/usr/bin/env bash
# _color-inject <session> <color>
#
# Thin wrapper over _cmd-inject (the generic injector): set a Claude Code session's
# prompt-bar color via the `/color` slash command, delivered through the fleet's own
# inspector transport -- the same mechanism `msg` uses, so there's one way messages reach
# a session and no tmux send-keys anywhere. Kept as a named entry point for the worker
# spawn/revive paths (worker-new / worker-open); the readiness-wait + submit logic lives
# in _cmd-inject. Any failure is SILENT (no `set -e`) -- coloring must never affect a
# session.
set -uo pipefail

sess="${1:-}"; color="${2:-}"
[ -n "$sess" ] && [ -n "$color" ] || exit 0

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[ -x "$SELF/_cmd-inject" ] || exit 0
exec "$SELF/_cmd-inject" "$sess" "/color $color"
