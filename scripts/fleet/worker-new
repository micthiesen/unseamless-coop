#!/usr/bin/env bash
# worker-new [--solo] <name> [guidance...]
#
# Materialize a worker: a rift copy-on-write workspace on its own branch, with a
# Claude Code session running in a detached tmux session (popped open in
# Alacritty), seeded to read its assignment. See docs/ORCHESTRATION.md.
#
#   worker-new boot-volume "Implement the boot_volume feature; see docs/FEATURES.md."
#
# --solo: a USER-DRIVEN worker. Michael drives the session interactively; it stays
# silent toward the orchestrator until he hands off, revives with the worker-solo.md
# overlay, and has no assignment file (guidance, if given, is its first prompt directly).
#   worker-new --solo scratch
#   worker-new --solo scratch "Start by refactoring the config loader."
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SELF/../.." && pwd)"
FLEET_DIR="${UNSEAMLESS_FLEET_DIR:-$HOME/.local/share/unseamless-fleet}"

# Distinct, stable per-session coloring (see scripts/fleet/_color). Guard the
# source so a future merge that drops the helper can't break a spawn -- with no
# helper, fleet_color_name yields nothing and coloring is simply skipped.
if [ -f "$SELF/_color" ]; then
  # shellcheck source=scripts/fleet/_color
  source "$SELF/_color"
else
  fleet_color_name() { :; }
fi

# --solo (user-driven) is an optional LEADING flag; everything after is the normal
# <name> [guidance...].
solo=0
if [ "${1:-}" = "--solo" ]; then
  solo=1; shift
fi

name="${1:-}"; shift || true
if [ -z "$name" ]; then
  echo "usage: worker-new [--solo] <name> [guidance...]" >&2
  exit 2
fi

# Role overlay (injected via --append-system-prompt-file) + the .role marker below:
# solo (user-driven) vs the default orchestrator-driven worker.
overlay_rel="docs/roles/worker.md"
if [ "$solo" -eq 1 ]; then
  overlay_rel="docs/roles/worker-solo.md"
fi
if ! [[ "$name" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
  echo "worker-new: name must be kebab-case [a-z0-9_-], got '$name'" >&2
  exit 2
fi
guidance="$*"

sess="usc-worker-$name"
branch="worker/$name"
ws="$HOME/Code/.rifts/$(basename "$REPO")/$name"

if tmux has-session -t "$sess" 2>/dev/null; then
  echo "worker-new: '$name' already has a live tmux session ($sess)" >&2
  exit 1
fi
if [ -e "$ws" ]; then
  echo "worker-new: workspace already exists at $ws (run 'worker-rm $name' first)" >&2
  exit 1
fi

cd "$REPO"
echo "==> rift create $name (runs .rift.toml postcreate hooks)"
log="$(mktemp)"
if ! rift create --name "$name" >"$log" 2>&1; then
  echo "worker-new: rift create failed:" >&2
  cat "$log" >&2
  # a failed postcreate hook can still leave the workspace registered; clean up
  [ -d "$ws" ] && { rift remove --force "$ws" >/dev/null 2>&1 || true; rift gc >/dev/null 2>&1 || true; }
  exit 1
fi
rm -f "$log"
if [ ! -d "$ws" ]; then
  echo "worker-new: expected workspace at $ws not found after create" >&2
  exit 1
fi
echo "    workspace: $ws"

echo "==> branch $branch"
git -C "$ws" switch -c "$branch"

# Trust the new workspace path so the worker's COW-copied .claude/settings.json
# allow rules + additionalDirectories actually load. Claude Code drops a project's
# permissions on an untrusted path, and each new rift workspace path is untrusted
# by default. ~/.claude.json is live, not git-tracked; edit it atomically.
echo "==> trust workspace in ~/.claude.json"
trust_json="$HOME/.claude.json"
if command -v jq >/dev/null 2>&1 && [ -f "$trust_json" ]; then
  cp "$trust_json" "$trust_json.bak" 2>/dev/null || true
  if tmp="$(mktemp)" && jq --arg p "$ws" '.projects[$p].hasTrustDialogAccepted = true' "$trust_json" >"$tmp" 2>/dev/null && [ -s "$tmp" ]; then
    mv "$tmp" "$trust_json"
    echo "    trusted $ws"
  else
    rm -f "${tmp:-}"
    echo "    WARNING: could not set workspace trust; worker may drop its allow rules until you accept its trust dialog once." >&2
  fi
else
  echo "    NOTE: jq or ~/.claude.json missing; accept the worker's trust dialog once so its permissions load." >&2
fi

# Role marker (outside the workspace, so it survives the COW copy): lets worker-open
# revive with the right overlay and worker-ls/worker-prune tell solo from orchestrator.
mkdir -p "$FLEET_DIR/assignments"
if [ "$solo" -eq 1 ]; then echo solo; else echo worker; fi >"$FLEET_DIR/assignments/$name.role"

if [ "$solo" -eq 1 ]; then
  # Solo: user-driven, no assignment-file indirection. Guidance (if any) is the first
  # prompt directly; with none, the session launches waiting for Michael's first turn.
  echo "==> solo (user-driven) worker; no assignment file"
  seed="$guidance"
else
  echo "==> assignment"
  assignment="$FLEET_DIR/assignments/$name.md"
  {
    echo "# Worker Assignment: $name"
    echo
    echo "- **Your name:** \`$name\` (sign messages \`[worker:$name]\`)"
    echo "- **Workspace:** \`$ws\`"
    echo "- **Branch:** \`$branch\` (WIP-commit here freely; never commit to \`main\`)"
    echo "- **Reach the orchestrator:** \`scripts/fleet/msg usc-orch \"[worker:$name] ...\"\`"
    echo
    echo "## Task"
    echo
    if [ -n "$guidance" ]; then
      echo "$guidance"
    else
      echo "_(none provided at launch; the orchestrator will message you.)_"
    fi
  } >"$assignment"
  echo "    $assignment"
  seed="Read $assignment for your assignment (you are worker:$name). Then begin."
fi

echo "==> launching Claude Code in tmux session $sess"
if [ ! -f "$ws/$overlay_rel" ]; then
  echo "worker-new: $ws/$overlay_rel missing -- the worker role overlay won't load." >&2
  echo "            Commit $overlay_rel so rift copies it into workspaces, then retry." >&2
  exit 1
fi
# The seed (set above per solo/non-solo) launches as a prompt ARG so it's never dropped.
# Optional via seed_args so an empty solo seed passes nothing (not an empty "") and the
# session launches waiting for the user's first turn.
seed_args=()
if [ -n "$seed" ]; then seed_args=("$seed"); fi
# tmux runs the command directly (no shell), so no quoting hazard on the seed.
# `--name` is a display badge only (prompt box / window title / resume picker); it
# never resumes, so every spawn is a fresh session regardless of the badge.
# `BUN_INSPECT=ws+unix://...` opens this session's inspector socket -- the one
# transport `msg`/`_inject`/coloring deliver through (the socket path is derived
# from $sess on both ends). Opening it is inert until something connects; clear any
# stale socket from a prior same-named session first. FLEET_DIR is propagated so the
# session and msg agree on the socket dir.
# The seed stays a LAUNCH ARG so it can never be dropped; coloring (below) is
# layered on separately and is purely best-effort.
mkdir -p "$FLEET_DIR/insp" && chmod 700 "$FLEET_DIR/insp"
rm -f "$FLEET_DIR/insp/$sess.sock"
tmux new-session -d -s "$sess" -c "$ws" \
  env UNSEAMLESS_FLEET_DIR="$FLEET_DIR" \
  BUN_INSPECT="ws+unix://$FLEET_DIR/insp/$sess.sock" \
  claude --name "usc-$name" \
  --append-system-prompt-file "$ws/$overlay_rel" "${seed_args[@]}"

if [ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ] && command -v alacritty >/dev/null 2>&1; then
  setsid -f alacritty -e tmux attach -t "$sess" >/dev/null 2>&1 || true
  echo "    opened Alacritty attached to $sess"
else
  echo "    no display detected; attach with:  tmux attach -t $sess"
fi

# Per-session prompt-bar color, fully decoupled from the seed above. A DETACHED
# injector waits for the session's inspector socket + prompt to be ready, then sends
# `/color` through it (queued behind the seed turn); if it never becomes injectable,
# or the helper is missing, the worker just goes uncolored -- never unseeded.
color="$(fleet_color_name "$name" 2>/dev/null || true)"
if [ -n "$color" ] && [ -x "$SELF/_color-inject" ]; then
  echo "    coloring session $color (best-effort, once injectable)"
  setsid -f "$SELF/_color-inject" "$sess" "$color" >/dev/null 2>&1 || true
fi

echo
if [ "$solo" -eq 1 ]; then
  echo "solo (user-driven) worker '$name' is up. Drive it directly in its window."
  echo "  integrate:   scripts/fleet/worker-integrate $name   (when you hand it off)"
  echo "  remove:      scripts/fleet/worker-rm $name"
  # No usc-orch nag: a solo worker intentionally stays silent toward the orchestrator.
else
  echo "worker '$name' is up."
  echo "  message it:  scripts/fleet/msg $sess \"[orchestrator] ...\""
  echo "  integrate:   scripts/fleet/worker-integrate $name"
  echo "  remove:      scripts/fleet/worker-rm $name"

  if ! tmux has-session -t usc-orch 2>/dev/null; then
    echo
    echo "  NOTE: no 'usc-orch' session is running, so this worker's messages to the"
    echo "        orchestrator will fail until you start one:  scripts/fleet/orch-start"
  fi
fi
