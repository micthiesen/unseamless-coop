#!/usr/bin/env bash
# msg <tmux-session> <text...>   (or pipe text on stdin)
#
# Deliver a message to another fleet Claude session. The message lands as a normal
# user turn in the target, delivered in-process through its inspector socket by the
# one complex piece, scripts/fleet/_inject (see that file for the mechanism). This
# replaces the old inbox+lifecycle-hook+wake-sentinel transport: delivery is now
# instant (no waiting for a Stop/SessionStart hook), the target need not be poked
# with a typed sentinel, and a draft left in the target's input box is saved and
# restored rather than gating delivery. If the target is mid-turn, the message
# queues and runs at the end of the current turn, exactly like typing would.
#
# Targets must be launched with BUN_INSPECT (worker-new / orch-start do this); the
# socket lives at $UNSEAMLESS_FLEET_DIR/insp/<session>.sock. Convention:
#   msg usc-orch                 "[worker:auth] need a rig run for the save hook"
#   msg usc-worker-auth          "[orchestrator] rig says the hook fired; proceed"
#
# Under the codex harness (scripts/fleet/harness) the transport is different: the
# Codex TUI is a Rust binary with no inspector socket, so delivery is a tmux
# bracketed paste into the target pane + Enter (see the codex branch below).
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLEET_DIR="${UNSEAMLESS_FLEET_DIR:-$HOME/.local/share/unseamless-fleet}"
# shellcheck source=scripts/fleet/_harness
source "$SELF/_harness"

sess="${1:-}"; shift || true
if [ -z "$sess" ]; then
  echo "usage: msg <tmux-session> <text...>   (or pipe text on stdin)" >&2
  exit 2
fi
# Only ever target fleet sessions, so a typo can't deliver into an unrelated pane.
if ! [[ "$sess" =~ ^usc-(orch|worker-[a-z0-9][a-z0-9_-]*)$ ]]; then
  echo "msg: refusing target '$sess' -- only fleet sessions (usc-orch, usc-worker-<name>) allowed" >&2
  exit 2
fi
if [ "$#" -gt 0 ]; then text="$*"; else text="$(cat)"; fi
if [ -z "$text" ]; then echo "msg: empty message" >&2; exit 2; fi

# Codex harness: deliver by tmux bracketed paste + Enter. Verified live: the
# paste lands in the composer and Enter submits it as a normal user turn, and a
# message sent while the target is mid-turn queues and runs when the turn ends
# (same as typing). Two caveats vs the claude injector: a draft sitting in the
# target's composer is NOT preserved (the paste appends to it and Enter submits
# the combined text), and a TUI still booting can drop the paste -- if a worker
# was spawned seconds ago, retry shortly. Multi-line text is fine: bracketed
# paste (-p) keeps newlines literal in the composer.
if [ "$(fleet_harness)" = "codex" ]; then
  if ! tmux has-session -t "$sess" 2>/dev/null; then
    echo "msg: $sess is offline (no tmux session); cannot deliver" >&2
    exit 1
  fi
  # Per-process buffer name: a fixed name races when two msg calls overlap (the
  # second load-buffer overwrites before the first paste-buffer fires).
  buf="usc-msg-$$"
  printf '%s' "$text" | tmux load-buffer -b "$buf" -
  tmux paste-buffer -p -t "$sess" -b "$buf" -d
  sleep 0.4
  tmux send-keys -t "$sess" Enter
  echo "msg: delivered to $sess (tmux paste)"
  exit 0
fi

sock="$FLEET_DIR/insp/$sess.sock"
if [ ! -S "$sock" ]; then
  echo "msg: $sess is offline (no inspector socket at $sock); cannot deliver" >&2
  exit 1
fi

# _inject does the work: connect, locate the prompt UI in the live React tree, submit
# the message as a turn, preserve any draft. Its exit code is the delivery result.
#
# Scrub BUN_INSPECT from the child's env. This script runs *inside* a fleet Claude
# whose own env carries BUN_INSPECT=ws+unix://.../<that session>.sock (worker-new /
# orch-start set it so the session exposes its inspector). bun honors BUN_INSPECT in
# EVERY child process, so an un-scrubbed `bun _inject` re-binds the caller's own
# inspector path on startup -- unlinking the caller's live socket and leaving a dead
# orphan file, after which nobody can `msg` the caller until it restarts. The injector
# only ever *connects* to the target's socket (--sock); it never needs its own
# inspector, so dropping BUN_INSPECT is free and stops the self-clobber. (Re-derive:
# `BUN_INSPECT=ws+unix:///tmp/x.sock bun -e 0` creates /tmp/x.sock -- bun binds it in
# any child.)
if env -u BUN_INSPECT bun "$SELF/_inject" --sock "$sock" -- "$text"; then
  echo "msg: delivered to $sess (live turn)"
else
  rc=$?
  if [ "$rc" -eq 8 ]; then
    echo "msg: $sess has a stale inspector socket -- the file exists but nothing is accepting on it." >&2
    echo "msg: the session restarted (or its socket was clobbered) and can't be reached on demand;" >&2
    echo "msg: restart it via orch-start / worker-open to rebind a fresh socket." >&2
  else
    echo "msg: delivery to $sess failed (rc=$rc); is it mid-restart? retry shortly" >&2
  fi
  exit "$rc"
fi
