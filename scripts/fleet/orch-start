#!/usr/bin/env bash
# orch-start [claude args...]
#
# Start (or attach to) the orchestrator Claude Code session. It runs in a tmux
# session named `usc-orch` so workers can reach it with `msg usc-orch ...`, and
# launches with `--add-dir` over the rifts tree so it can fetch/integrate worker
# branches. No worker role overlay -> it is the orchestrator by default
# (CLAUDE.md). See docs/ORCHESTRATION.md.
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SELF/../.." && pwd)"
RIFTS="$HOME/Code/.rifts/$(basename "$REPO")"
FLEET_DIR="${UNSEAMLESS_FLEET_DIR:-$HOME/.local/share/unseamless-fleet}"
sess="usc-orch"

# Distinct, stable per-session coloring (see scripts/fleet/_color). Guard the
# source so a future merge that drops the helper can't break a spawn.
if [ -f "$SELF/_color" ]; then
  # shellcheck source=scripts/fleet/_color
  source "$SELF/_color"
else
  fleet_color_name() { :; }
fi

mkdir -p "$RIFTS"

if tmux has-session -t "$sess" 2>/dev/null; then
  echo "orchestrator session '$sess' already running; attaching."
  exec tmux attach -t "$sess"
fi

cd "$REPO"
# `--name` is a display badge only (never resumes); "$@" comes last so a
# user-supplied --name overrides this default. `BUN_INSPECT=...` opens the
# orchestrator's inspector socket so workers can `msg usc-orch` into it (the same
# transport workers use); inert until connected. Clear any stale socket first.
mkdir -p "$FLEET_DIR/insp" && chmod 700 "$FLEET_DIR/insp"
rm -f "$FLEET_DIR/insp/$sess.sock"
tmux new-session -d -s "$sess" -c "$REPO" \
  env UNSEAMLESS_FLEET_DIR="$FLEET_DIR" \
  BUN_INSPECT="ws+unix://$FLEET_DIR/insp/$sess.sock" \
  claude --name "usc-orch" --add-dir "$RIFTS" "$@"
# Reserved orchestrator color (red), best-effort and ONLY on a fresh start (this
# branch) -- the attach-existing path above leaves a running session untouched.
# Detached, so the attach below is never delayed while it waits for the socket.
color="$(fleet_color_name "usc-orch" 2>/dev/null || true)"
if [ -n "$color" ] && [ -x "$SELF/_color-inject" ]; then
  setsid -f "$SELF/_color-inject" "$sess" "$color" >/dev/null 2>&1 || true
fi
exec tmux attach -t "$sess"
