#!/usr/bin/env bash
# worker-ls
#
# List active workers, derived live from `rift list` + tmux (no registry file to
# drift). Also flags orphan tmux sessions with no matching workspace.
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SELF/../.." && pwd)"
FLEET_DIR="${UNSEAMLESS_FLEET_DIR:-$HOME/.local/share/unseamless-fleet}"
# shellcheck source=scripts/fleet/_harness
source "$SELF/_harness"
harness="$(fleet_harness)"

cd "$REPO"

# AHEAD = commits on the worker branch beyond the workspace's own copy of `main`
# (the create point) -- the at-a-glance "has this worker produced anything yet?"
# signal. Worker branches live in the independent workspace clones, not here, so
# this is computed per-workspace (`git -C "$ws"`), not from the orchestrator repo.
# ROLE (worker|solo|-) comes from the `.role` marker; solo workers are the ones
# `worker-prune` sweeps up.
# SOCK = whether `msg` can reach a live session. claude harness: its inspector
# socket (worker-new/orch-start set BUN_INSPECT to $FLEET_DIR/insp/<sess>.sock) is
# present -- the cheap mirror of msg's first gate (`[ -S "$sock" ]`); it does NOT
# prove something is *accepting* on it (a restarted session can leave a stale file
# -- msg's deeper rc=8 check catches that). codex harness: the tmux session itself
# is the transport (msg pastes into the pane), so live == reachable. `up` =
# reachable, `off` = live but no socket (claude msg would fail), `-` = no live
# session. We don't spawn a per-worker `_inject --selftest` probe here; that'd
# fork a bun per row and make `ls` slow.
# LAST_COMMIT = the worker branch tip's subject -- *what* each worker is building, not
# just that it's ahead. `(no commits yet)` when AHEAD is 0 (tip is still the base), so a
# base-commit subject never reads as the worker's own work.
printf '%-18s %-5s %-5s %-6s %-22s %-6s %-6s %s\n' NAME TMUX SOCK ROLE BRANCH DIRTY AHEAD LAST_COMMIT
found=0
while IFS= read -r ws; do
  [ -n "$ws" ] || continue
  found=1
  name="$(basename "$ws")"
  sess="usc-worker-$name"
  if tmux has-session -t "$sess" 2>/dev/null; then tstate="live"; else tstate="-"; fi
  if [ "$tstate" = "live" ]; then
    if [ "$harness" = "codex" ]; then
      sstate="up"   # tmux itself is the codex transport; live session == reachable
    else
      [ -S "$FLEET_DIR/insp/$sess.sock" ] && sstate="up" || sstate="off"
    fi
  else
    sstate="-"
  fi
  role="-"; [ -f "$FLEET_DIR/assignments/$name.role" ] && role="$(cat "$FLEET_DIR/assignments/$name.role")"
  branch="$(git -C "$ws" branch --show-current 2>/dev/null || true)"
  [ -n "$branch" ] || branch="(detached)"
  if git -C "$ws" diff --quiet 2>/dev/null && git -C "$ws" diff --cached --quiet 2>/dev/null; then
    dirty="clean"
  else
    dirty="dirty"
  fi
  ahead="$(git -C "$ws" rev-list --count main..HEAD 2>/dev/null || echo '?')"
  if [ "$ahead" = "0" ]; then
    last="(no commits yet)"
  else
    last="$(git -C "$ws" log -1 --format=%s HEAD 2>/dev/null || true)"
    [ -n "$last" ] || last="-"
  fi
  [ "${#last}" -gt 50 ] && last="${last:0:49}…"   # keep the free-width tail to one line
  printf '%-18s %-5s %-5s %-6s %-22s %-6s %-6s %s\n' "$name" "$tstate" "$sstate" "$role" "$branch" "$dirty" "$ahead" "$last"
done < <(rift list 2>/dev/null)

if [ "$found" -eq 0 ]; then
  echo "(no worker workspaces)"
fi

# Flag orphans: a live tmux session with no matching workspace.
while IFS= read -r sess; do
  [ -n "$sess" ] || continue
  name="${sess#usc-worker-}"
  [ -d "$HOME/Code/.rifts/$(basename "$REPO")/$name" ] || \
    echo "orphan tmux session (no workspace): $sess  -> tmux kill-session -t $sess"
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^usc-worker-' || true)

if [ "$found" -eq 1 ]; then
  echo
  echo "tip: reopen/revive a worker window -> scripts/fleet/worker-open <name>"
  echo "     each worker's workspace is at  $HOME/Code/.rifts/$(basename "$REPO")/<name>"
fi
