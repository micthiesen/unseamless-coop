#!/usr/bin/env bash
# inbox pop                -- take (read + REMOVE) your own session's pending messages now
# inbox wait [timeout]     -- block until your own inbox has mail, then pop it
# inbox ls                 -- list pending message counts per session (read-only overview)
# inbox state [<session>]  -- show the hook-stamped busy/idle state (read-only)
#
# Receiving is **pop**: read-and-remove, atomically, in one step. That is the only
# way to take a message off the transport -- there is deliberately no separate
# "peek then delete" path to get out of sync (and nothing ever hand-deletes a
# `.msg` file). Normal sessions don't even call this: their lifecycle hooks
# (`_hook`) pop the inbox automatically each turn. `pop`/`wait` are the manual
# equivalents for an autonomous orchestrator that wants to *block* on a worker
# reply mid-turn (when no Stop hook will fire to deliver it). Both act only on
# YOUR OWN inbox ($UNSEAMLESS_FLEET_SESSION), so they can never steal another
# session's undelivered mail. See _inbox and docs/ORCHESTRATION.md.
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/fleet/_inbox
. "$SELF/_inbox"

# Resolve "my own inbox" for pop/wait. Refuse rather than guess: popping the wrong
# inbox would consume mail meant for another session.
own_session() {
  local s="${UNSEAMLESS_FLEET_SESSION:-}"
  if [ -z "$s" ]; then
    echo "inbox $1: must run inside a fleet session (UNSEAMLESS_FLEET_SESSION unset)" >&2
    exit 2
  fi
  printf '%s' "$s"
}

cmd="${1:-ls}"; shift || true

case "$cmd" in
  pop)
    sess="$(own_session pop)"
    if drained="$(fleet_inbox_drain "$sess")"; then
      printf '%s\n' "$drained"
    else
      echo "(inbox empty for $sess)"
      exit 1
    fi
    ;;

  wait)
    sess="$(own_session wait)"
    timeout="${1:-600}"
    case "$timeout" in (*[!0-9]*|'') echo "usage: inbox wait [timeout-seconds]" >&2; exit 2;; esac
    waited=0
    while :; do
      if drained="$(fleet_inbox_drain "$sess")"; then
        printf '%s\n' "$drained"
        exit 0
      fi
      [ "$waited" -lt "$timeout" ] || break
      sleep 2
      waited=$((waited + 2))
    done
    echo "inbox wait: timed out after ${timeout}s with no message for $sess" >&2
    exit 3
    ;;

  ls)
    root="$UNSEAMLESS_FLEET_DIR/inbox"
    [ -d "$root" ] || { echo "(no inboxes)"; exit 0; }
    found=0
    for d in "$root"/*/; do
      [ -d "$d" ] || continue
      s="$(basename "$d")"
      n="$(fleet_inbox_files "$s" | wc -l | tr -d ' ')"
      [ "$n" -gt 0 ] || continue
      printf '%-28s %s pending\n' "$s" "$n"
      found=1
    done
    [ "$found" -eq 1 ] || echo "(all inboxes empty)"
    ;;

  state)
    sess="${1:-}"
    if [ -n "$sess" ]; then
      printf '%-28s %s\n' "$sess" "$(fleet_state_read "$sess")"
    else
      d="$UNSEAMLESS_FLEET_DIR/state"
      [ -d "$d" ] || { echo "(no state recorded)"; exit 0; }
      for f in "$d"/*; do
        [ -f "$f" ] || continue
        printf '%-28s %s\n' "$(basename "$f")" "$(cat "$f")"
      done
    fi
    ;;

  *)
    echo "usage: inbox {pop | wait [timeout] | ls | state [<session>]}" >&2
    exit 2
    ;;
esac
