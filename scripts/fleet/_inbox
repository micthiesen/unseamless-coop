# shellcheck shell=bash
# _inbox -- shared fleet message-passing primitives (sourced, not executed).
#
# The transport is a per-session **inbox** (a maildir-style directory of message
# files) drained by Claude Code lifecycle hooks (`_hook`), instead of typing the
# message into the target's TTY. This is what stops a worker message from
# clobbering what you're typing into the orchestrator: message *content* never
# goes through stdin -- only a fixed one-line wake sentinel ever does, and only to
# a parked-idle worker (never to the human-attended orchestrator).
#
# Delivery correctness lives in the inbox: `msg` appends here first, and every
# Stop / UserPromptSubmit / SessionStart hook drains it. The wake sentinel is a
# pure latency optimization (wake a parked session that no hook would otherwise
# fire on) -- if it's skipped or lost, the message still delivers on the target's
# next lifecycle event. See docs/ORCHESTRATION.md.

: "${UNSEAMLESS_FLEET_DIR:=$HOME/.local/share/unseamless-fleet}"

# The exact one-line prompt a wake-poke types into a parked session. `_hook`
# matches it to recognise a stray poke (one that races an inbox already drained by
# a Stop) and swallow it. Keep `msg` and `_hook` agreeing via this single source.
# Factual, not an imperative "do X now" — out-of-band command phrasing can trip Claude's
# prompt-injection defense and get the text surfaced instead of acted on. The role overlay +
# the message body carry the actual instruction.
# shellcheck disable=SC2034  # consumed by sourcing scripts (msg, _hook)
FLEET_WAKE_SENTINEL="[fleet] A message from another fleet session is shown below."

fleet_inbox_dir()  { printf '%s' "$UNSEAMLESS_FLEET_DIR/inbox/$1"; }
fleet_state_file() { printf '%s' "$UNSEAMLESS_FLEET_DIR/state/$1"; }

# fleet_inbox_files <sess>  ->  message file paths, oldest first (chronological)
# The single owner of the inbox enumeration contract (the `*.msg` glob, maxdepth, sort), so
# drain and the `inbox` viewer can't drift from each other.
fleet_inbox_files() {
  local dir; dir="$(fleet_inbox_dir "$1")"
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -type f -name '*.msg' 2>/dev/null | sort
}

# fleet_inbox_append <sess>   (message text on stdin)
# Write the message as one file, atomically (temp + rename) so a concurrent drain
# never reads a half-written message. Unique, time-ordered filename.
fleet_inbox_append() {
  local sess="$1" dir tmp f
  dir="$(fleet_inbox_dir "$sess")"
  mkdir -p "$dir"
  tmp="$(mktemp "$dir/.tmp.XXXXXX")"
  cat >"$tmp"
  # %s%N + pid + $RANDOM: time-ordered for the drain's sort, and unique without relying on
  # nanosecond resolution, so `mv` can never clobber a same-instant sibling.
  f="$dir/$(date +%s%N)-$$-$RANDOM.msg"
  mv -f "$tmp" "$f"
}

# fleet_inbox_drain <sess>  ->  concatenated messages on stdout (chronological)
# Returns 0 if at least one message was drained, 1 if the inbox was empty. Each message file is
# removed as it's read (read-then-delete). Within one session this is delivered-once: the only
# drainer of a session's inbox is that session's own hooks, which fire sequentially.
fleet_inbox_drain() {
  local sess="$1" f had=1 files=()
  while IFS= read -r f; do files+=("$f"); done < <(fleet_inbox_files "$sess")
  [ "${#files[@]}" -gt 0 ] || return 1
  for f in "${files[@]}"; do
    [ -f "$f" ] || continue
    cat "$f"
    printf '\n'
    rm -f "$f"
    had=0
  done
  return "$had"
}

# fleet_state_write <sess> <busy|idle>
# The hooks stamp the session's turn lifecycle here (UserPromptSubmit/PostToolUse
# -> busy, Stop/SessionStart -> idle) so `msg` can read an authoritative busy/idle
# without scraping the TUI.
fleet_state_write() {
  local d="$UNSEAMLESS_FLEET_DIR/state" now
  [ -d "$d" ] || mkdir -p "$d"          # avoid a fork on the PostToolUse hot path
  printf -v now '%(%s)T' -1             # epoch seconds, bash builtin (no `date` fork)
  printf '%s %s\n' "$2" "$now" >"$d/$1"
}

# fleet_state_read <sess>  ->  "<busy|idle> <epoch-seconds>"  (idle 0 if unknown/empty)
# `-s` (exists and non-empty) so a torn read of a being-rewritten file falls back to the safe
# default rather than emitting nothing (which would abort a `read` under `set -e`).
fleet_state_read() {
  local f; f="$(fleet_state_file "$1")"
  if [ -s "$f" ]; then cat "$f"; else printf 'idle 0\n'; fi
}

# fleet_session_composing <sess>  ->  0 if a human appears to be typing into it
# Used by `msg` to avoid waking (typing into) a session someone is composing in.
# It declares "composing" only when the session was active very recently AND its
# pane is still changing between two samples. A long-idle session has stale
# activity -> not composing.
#
# Caveat this CANNOT see on its own: a session that just ended a turn is *also*
# recently-active with a changing pane -- it's repainting its response and
# blinking the input cursor, not being typed into. So this returns a false
# "composing" right after a turn. `msg` compensates with the authoritative hook
# state (SETTLE_GRACE): it skips this heuristic for a worker whose idle stamp is
# only seconds old. Don't rely on this function alone to mean "a human is typing."
fleet_session_composing() {
  local sess="$1" last now delta a b
  command -v tmux >/dev/null 2>&1 || return 1
  tmux has-session -t "$sess" 2>/dev/null || return 1
  last="$(tmux display-message -p -t "$sess" '#{session_activity}' 2>/dev/null || echo 0)"
  [[ "$last" =~ ^[0-9]+$ ]] || last=0
  # Normalise to epoch seconds (tmux reports ms on some builds, s on others).
  [ "$last" -gt 100000000000 ] && last=$((last / 1000))
  now="$(date +%s)"
  delta=$((now - last))
  [ "$delta" -lt 2 ] || return 1   # not active in the last ~2s -> not composing
  a="$(tmux capture-pane -p -t "$sess" 2>/dev/null || true)"
  sleep 0.15
  b="$(tmux capture-pane -p -t "$sess" 2>/dev/null || true)"
  [ "$a" != "$b" ]                 # pane still changing -> a human is typing
}
